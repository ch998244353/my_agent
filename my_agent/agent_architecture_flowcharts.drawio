                <mxCell id="1" parent="0"/>
                <mxCell id="te_title" value="toolexecute 详细流程&#xa;tools.py + agent_tools.py + run_steps.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#111827;fontColor=#ffffff;fontStyle=1;fontSize=18;align=center;verticalAlign=middle;" parent="1" vertex="1">
