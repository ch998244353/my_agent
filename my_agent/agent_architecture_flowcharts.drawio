                    <mxGeometry x="120" y="145" width="250" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="ho_normalize" value="normalize_handoff_name(agent.name)&#xa;小写 + 非字母数字转下划线&#xa;空名称回退 agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="120" y="260" width="300" height="90" as="geometry"/>
                </mxCell>
