                <mxCell id="ho_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;" parent="1" source="ho_prepare" target="ho_model" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
