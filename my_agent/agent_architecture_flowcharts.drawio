                    <mxGeometry x="140" y="395" width="260" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="ho_specs" value="handoff_tool_specs()&#xa;生成模型可见 ToolSpec&#xa;参数: task: string&#xa;returns: object" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="100" y="515" width="340" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ho_prepare" value="prepare_turn_input()&#xa;普通工具 specs + handoff specs&#xa;一起交给模型选择" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="520" y="170" width="330" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ho_model" value="模型返回 ToolCall&#xa;tool_name = transfer_to_xxx&#xa;arguments.task 可选" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="535" y="310" width="300" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ho_target_lookup" value="handoff_target_for(handoffs, action)&#xa;handoff_map()[action.tool_name]" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="565" y="455" width="240" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="ho_not_handoff" value="未命中目标&#xa;交给 execute_tool_call()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
                    <mxGeometry x="950" y="480" width="250" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="ho_execute" value="execute_handoff()&#xa;提取 task&#xa;缺省时使用 agent.memory.task 或空字符串&#xa;创建 handoff_span" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="500" y="625" width="370" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="ho_emit" value="_execute_handoff_impl()&#xa;emit_handoff(hooks, context, source, target)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
                    <mxGeometry x="525" y="780" width="320" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="ho_child" value="target_agent.run(task)&#xa;递归进入目标 Agent 的 agentloop&#xa;返回 RunResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="510" y="900" width="350" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ho_update_state" value="回写父 RunState&#xa;record_tool_step()&#xa;final_answer = target_result.final_answer&#xa;reached_final_answer = target_result.reached_final_answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="500" y="1035" width="370" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="ho_items" value="追加 RunItem&#xa;item_type=handoff&#xa;metadata: target_agent, task&#xa;若目标已 final: 再追加 final_output" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="100" y="905" width="320" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="ho_memory" value="父 Agent 记忆记录&#xa;agent.memory.add_step(StepRecord)&#xa;tool_calls=[handoff action]&#xa;observation=Handoff to target returned..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="965" y="895" width="330" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="ho_after" value="回到 run_loop&#xa;若 handoff_outcome.reached_final_answer&#xa;last_agent = target_agent&#xa;再跑父级 output_guardrails" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="500" y="1185" width="370" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="ho_break" value="handoff_happened = True&#xa;break 当前 tool_calls 循环&#xa;父 agentloop 结束或停止" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="530" y="1335" width="310" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="ho_note" value="源码依据: src/agents/handoffs.py, agent.py:_handoff_tool_specs/_handoff_target_for, run_loop.py, run_steps.py:execute_handoff&#xa;handoff 本质上被建模为模型可调用工具，但执行时走专门分支，不经过 ToolRegistry。" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1470" width="1260" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="ho_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;" parent="1" source="ho_targets" target="ho_normalize" edge="1">
