                </mxCell>
                <mxCell id="te_disabled" value="禁用或不存在&#xa;抛出异常&#xa;run_loop 捕获后 record_tool_error()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
